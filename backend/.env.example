# ── Database ──────────────────────────────────────────────────────────────────
# Async PostgreSQL connection URL (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://docqa:docqa@localhost:5432/docqa

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── JWT Authentication ────────────────────────────────────────────────────────
# Change to a long random string in production
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# ── File Storage ──────────────────────────────────────────────────────────────
# "local" stores files on the local filesystem
# "s3"    uploads files to Amazon S3
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=/data/uploads

# S3 settings (only required when STORAGE_BACKEND=s3)
S3_BUCKET=docqa-uploads
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# ── Limits ────────────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50
RATE_LIMIT_REQUESTS_PER_MINUTE=30
