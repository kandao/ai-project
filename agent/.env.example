# LLM Provider — "anthropic" or "openai"
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6

# API Keys
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Optional: override API endpoints for compatible providers (e.g. MiniMax)
# ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic
# OPENAI_BASE_URL=https://api.minimax.io/v1

# ── Kafka / streaming mode (Agent02) ──────────────────────────────────
# Set KAFKA_BOOTSTRAP_SERVERS to activate Kafka consumer mode
# KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# KAFKA_GROUP_ID=agent-group
# KAFKA_TOPIC=chat.query

# Redis pub/sub for streaming responses to clients
# REDIS_URL=redis://localhost:6379

# ── Database (Agent02 + Agent03) ──────────────────────────────────────
# PostgreSQL connection string used by hybrid_retrieval and query_database
# when no per-user db_url is available (CLI mode / fallback)
# DATABASE_URL=postgresql://user:password@localhost:5432/agentdb

# ── Embeddings (Agent02 retrieval) ────────────────────────────────────
# Provider for query embeddings: "voyage" | "cohere" | "openai"
# EMBEDDING_PROVIDER=openai
# Model override (optional — provider default used if unset)
# EMBEDDING_MODEL=text-embedding-3-small

# Voyage AI key (required if EMBEDDING_PROVIDER=voyage)
# VOYAGE_API_KEY=pa-...

# Cohere key (required if EMBEDDING_PROVIDER=cohere)
# COHERE_API_KEY=...

# ── Per-user access control (Agent03) ─────────────────────────────────
# Internal URL of the backend service for token exchange
# BACKEND_INTERNAL_URL=http://backend:8000
